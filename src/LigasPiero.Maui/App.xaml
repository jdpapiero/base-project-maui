<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:LigasPiero.Maui"
             xmlns:converters="clr-namespace:LigasPiero.Maui.Converters"
             x:Class="LigasPiero.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:BoolToActiveConverter x:Key="BoolToActiveConverter" />
            <converters:BoolToButtonColorConverter x:Key="BoolToButtonColorConverter" />
            <converters:BoolToButtonColorInverseConverter x:Key="BoolToButtonColorInverseConverter" />
            <converters:OwnGoalConverter x:Key="OwnGoalConverter" />
            <converters:CardTypeColorConverter x:Key="CardTypeColorConverter" />
            <converters:StarterConverter x:Key="StarterConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
