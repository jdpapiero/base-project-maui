<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LigasPiero.Maui.ViewModels"
             x:Class="LigasPiero.Maui.Views.Public.LeagueSelectionPage"
             x:DataType="vm:LeagueSelectionViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*" Padding="16">
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <Label Text="⚽ Ligas Deportivas"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Primary}" />
            <Label Text="Seleccione una liga para ver los partidos"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="Gray" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12">
                <!-- Leagues Section -->
                <Label Text="Ligas Activas"
                       FontSize="20"
                       FontAttributes="Bold"
                       Margin="0,0,0,8" />

                <CollectionView ItemsSource="{Binding Leagues}"
                                SelectionMode="None"
                                EmptyView="No hay ligas activas disponibles">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Frame Padding="16" Margin="0,4" CornerRadius="12"
                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                                   BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                                   HasShadow="True">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LeagueSelectionViewModel}}, Path=SelectLeagueCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Name}"
                                           FontSize="18"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding Description}"
                                           FontSize="13"
                                           TextColor="Gray" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Seasons Section (visible when a league is selected) -->
                <VerticalStackLayout IsVisible="{Binding SelectedLeague, Converter={StaticResource IsNotNullConverter}}"
                                     Spacing="8"
                                     Margin="0,16,0,0">
                    <Label Text="Gestiones / Temporadas"
                           FontSize="20"
                           FontAttributes="Bold" />

                    <CollectionView ItemsSource="{Binding Seasons}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Frame Padding="12" Margin="0,4" CornerRadius="10"
                                       BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2C2C2E}"
                                       BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#444}">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LeagueSelectionViewModel}}, Path=SelectSeasonCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="12">
                                        <Label Text="📅" FontSize="24" VerticalOptions="Center" />
                                        <VerticalStackLayout VerticalOptions="Center">
                                            <Label Text="{Binding Name}"
                                                   FontSize="16"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding Year, StringFormat='Año: {0}'}"
                                                   FontSize="12"
                                                   TextColor="Gray" />
                                        </VerticalStackLayout>
                                        <Label Text="{Binding IsActive, Converter={StaticResource BoolToActiveConverter}}"
                                               FontSize="12"
                                               VerticalOptions="Center"
                                               HorizontalOptions="EndAndExpand"
                                               TextColor="Green" />
                                    </HorizontalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Color="{StaticResource Primary}" />
    </Grid>
</ContentPage>
