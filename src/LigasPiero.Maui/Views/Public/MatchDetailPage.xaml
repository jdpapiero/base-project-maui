<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LigasPiero.Maui.ViewModels"
             x:Class="LigasPiero.Maui.Views.Public.MatchDetailPage"
             x:DataType="vm:MatchDetailViewModel"
             Title="{Binding Title}">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">
            <!-- Score Header -->
            <Frame Padding="20" CornerRadius="16"
                   BackgroundColor="{StaticResource Primary}"
                   HasShadow="True">
                <Grid ColumnDefinitions="*,Auto,*" RowDefinitions="Auto,Auto">
                    <Label Grid.Row="0" Grid.Column="0"
                           Text="{Binding Match.HomeTeamName}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />
                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Margin="16,0">
                        <Label Text="{Binding Match.HomeGoals, StringFormat='{0}'}"
                               FontSize="36" FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                        <Label Text="-"
                               FontSize="20"
                               TextColor="White"
                               HorizontalTextAlignment="Center"
                               Margin="0,-8" />
                        <Label Text="{Binding Match.AwayGoals, StringFormat='{0}'}"
                               FontSize="36" FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                    <Label Grid.Row="0" Grid.Column="2"
                           Text="{Binding Match.AwayTeamName}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />

                    <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="3"
                                            HorizontalOptions="Center" Spacing="8" Margin="0,8,0,0">
                        <Label Text="{Binding Match.MatchDate, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                               FontSize="13" TextColor="#DDDDDD" />
                        <Label Text="•" TextColor="#DDDDDD" />
                        <Label Text="{Binding Match.Venue}"
                               FontSize="13" TextColor="#DDDDDD" />
                    </HorizontalStackLayout>
                </Grid>
            </Frame>

            <!-- Goals Section -->
            <Frame Padding="16" CornerRadius="12"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="⚽ Goles" FontSize="18" FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding Goals}"
                                    EmptyView="Sin goles registrados">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <HorizontalStackLayout Spacing="8" Padding="4">
                                    <Label Text="{Binding Minute, StringFormat=&quot;{0}&apos;&quot;}"
                                           FontSize="14" FontAttributes="Bold"
                                           TextColor="{StaticResource Primary}"
                                           WidthRequest="40" />
                                    <Label Text="{Binding PlayerName}" FontSize="14" />
                                    <Label Text="{Binding IsOwnGoal, Converter={StaticResource OwnGoalConverter}}"
                                           FontSize="12" TextColor="Red" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Cards Section -->
            <Frame Padding="16" CornerRadius="12"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="🟨 Tarjetas" FontSize="18" FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding Cards}"
                                    EmptyView="Sin tarjetas registradas">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <HorizontalStackLayout Spacing="8" Padding="4">
                                    <Label Text="{Binding Minute, StringFormat=&quot;{0}&apos;&quot;}"
                                           FontSize="14" FontAttributes="Bold"
                                           WidthRequest="40" />
                                    <BoxView WidthRequest="16" HeightRequest="20"
                                             CornerRadius="2"
                                             Color="{Binding Type, Converter={StaticResource CardTypeColorConverter}}" />
                                    <Label Text="{Binding PlayerName}" FontSize="14" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Lineup Section -->
            <Frame Padding="16" CornerRadius="12"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="📋 Planilla - Local" FontSize="18" FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding HomeLineup}"
                                    EmptyView="Sin planilla registrada">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <HorizontalStackLayout Spacing="8" Padding="4">
                                    <Label Text="{Binding ShirtNumber, StringFormat='#{0}'}"
                                           FontSize="14" FontAttributes="Bold"
                                           WidthRequest="40"
                                           TextColor="{StaticResource Primary}" />
                                    <Label Text="{Binding PlayerName}" FontSize="14" />
                                    <Label Text="{Binding IsStarter, Converter={StaticResource StarterConverter}}"
                                           FontSize="11" TextColor="Gray"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="16" CornerRadius="12"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="📋 Planilla - Visitante" FontSize="18" FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding AwayLineup}"
                                    EmptyView="Sin planilla registrada">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <HorizontalStackLayout Spacing="8" Padding="4">
                                    <Label Text="{Binding ShirtNumber, StringFormat='#{0}'}"
                                           FontSize="14" FontAttributes="Bold"
                                           WidthRequest="40"
                                           TextColor="{StaticResource Primary}" />
                                    <Label Text="{Binding PlayerName}" FontSize="14" />
                                    <Label Text="{Binding IsStarter, Converter={StaticResource StarterConverter}}"
                                           FontSize="11" TextColor="Gray"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
