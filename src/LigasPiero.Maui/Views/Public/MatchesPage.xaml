<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LigasPiero.Maui.ViewModels"
             x:Class="LigasPiero.Maui.Views.Public.MatchesPage"
             x:DataType="vm:MatchesViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*" Padding="16">
        <!-- Toggle Buttons -->
        <HorizontalStackLayout Grid.Row="0" HorizontalOptions="Center" Spacing="8" Margin="0,8,0,16">
            <Button Text="📅 Próximos"
                    Command="{Binding ToggleViewCommand}"
                    BackgroundColor="{Binding ShowUpcoming, Converter={StaticResource BoolToButtonColorConverter}}"
                    TextColor="White"
                    CornerRadius="20"
                    Padding="16,8" />
            <Button Text="📋 Historial"
                    Command="{Binding ToggleViewCommand}"
                    BackgroundColor="{Binding ShowUpcoming, Converter={StaticResource BoolToButtonColorInverseConverter}}"
                    TextColor="White"
                    CornerRadius="20"
                    Padding="16,8" />
        </HorizontalStackLayout>

        <!-- Upcoming Matches -->
        <CollectionView Grid.Row="1"
                         ItemsSource="{Binding UpcomingMatches}"
                         IsVisible="{Binding ShowUpcoming}"
                         SelectionMode="None"
                         EmptyView="No hay partidos próximos programados">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Frame Padding="12" Margin="0,6" CornerRadius="12"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                           BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                           HasShadow="True">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MatchesViewModel}}, Path=ViewMatchDetailCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto,*">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding HomeTeamName}"
                                   FontSize="16" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" />
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="vs"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   Margin="12,0" />
                            <Label Grid.Row="0" Grid.Column="2"
                                   Text="{Binding AwayTeamName}"
                                   FontSize="16" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" />

                            <Label Grid.Row="1" Grid.ColumnSpan="3"
                                   Text="{Binding MatchDate, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                   FontSize="13"
                                   HorizontalTextAlignment="Center"
                                   TextColor="Gray"
                                   Margin="0,8,0,0" />

                            <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="3"
                                                    HorizontalOptions="Center" Spacing="4" Margin="0,4,0,0">
                                <Label Text="📍" FontSize="12" />
                                <Label Text="{Binding Venue}" FontSize="12" TextColor="Gray" />
                                <Label Text=" | " FontSize="12" TextColor="Gray" />
                                <Label Text="{Binding Matchday, StringFormat='Fecha {0}'}"
                                       FontSize="12" TextColor="Gray" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Past Matches -->
        <CollectionView Grid.Row="1"
                         ItemsSource="{Binding PastMatches}"
                         IsVisible="{Binding ShowUpcoming, Converter={StaticResource InvertedBoolConverter}}"
                         SelectionMode="None"
                         EmptyView="No hay partidos finalizados">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Frame Padding="12" Margin="0,6" CornerRadius="12"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}"
                           BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333}"
                           HasShadow="True">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MatchesViewModel}}, Path=ViewMatchDetailCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto,*">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding HomeTeamName}"
                                   FontSize="16" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" />
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Score}"
                                   FontSize="24" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   Margin="12,0" />
                            <Label Grid.Row="0" Grid.Column="2"
                                   Text="{Binding AwayTeamName}"
                                   FontSize="16" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" />

                            <Label Grid.Row="1" Grid.ColumnSpan="3"
                                   Text="{Binding MatchDate, StringFormat='{0:dd/MM/yyyy}'}"
                                   FontSize="13"
                                   HorizontalTextAlignment="Center"
                                   TextColor="Gray"
                                   Margin="0,4,0,0" />

                            <Label Grid.Row="2" Grid.ColumnSpan="3"
                                   Text="Finalizado ✅"
                                   FontSize="12"
                                   HorizontalTextAlignment="Center"
                                   TextColor="Green"
                                   Margin="0,4,0,0" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Color="{StaticResource Primary}" />
    </Grid>
</ContentPage>
