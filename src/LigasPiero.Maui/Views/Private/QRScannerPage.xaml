<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LigasPiero.Maui.ViewModels"
             x:Class="LigasPiero.Maui.Views.Private.QRScannerPage"
             x:DataType="vm:QRScannerViewModel"
             Title="{Binding Title}">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">
            <!-- Scanning Section -->
            <Frame IsVisible="{Binding IsScanning}"
                   Padding="24" CornerRadius="16"
                   BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2C2C2E}"
                   HasShadow="True">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <Label Text="📱" FontSize="80" HorizontalOptions="Center" />
                    <Label Text="Escanear Código QR"
                           FontSize="22" FontAttributes="Bold"
                           HorizontalOptions="Center" />
                    <Label Text="Apunte la cámara al código QR del jugador para verificar su información"
                           FontSize="14" TextColor="Gray"
                           HorizontalTextAlignment="Center" />

                    <Button Text="Simular Escaneo QR"
                            Command="{Binding SimulateScanCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="50"
                            Margin="0,8" />

                    <Label Text="ó ingrese el código manualmente:"
                           FontSize="12" TextColor="Gray"
                           HorizontalTextAlignment="Center" />

                    <Entry Text="{Binding ScannedCode}"
                           Placeholder="Ej: QR-BOL-0001"
                           HorizontalTextAlignment="Center"
                           ReturnCommand="{Binding SearchPlayerCommand}" />

                    <Button Text="Buscar"
                            Command="{Binding SearchPlayerCommand}"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            CornerRadius="12" />
                </VerticalStackLayout>
            </Frame>

            <!-- Player Info Section -->
            <VerticalStackLayout IsVisible="{Binding IsPlayerFound}" Spacing="12">
                <Frame Padding="20" CornerRadius="16"
                       BackgroundColor="{StaticResource Primary}"
                       HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="✅ Jugador Verificado"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding ScannedPlayer.FullName}"
                               FontSize="24" FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="16" CornerRadius="12"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C1E}">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
                        <Label Grid.Row="0" Grid.Column="0" Text="Equipo:" FontAttributes="Bold" />
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding ScannedPlayer.TeamName}" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Posición:" FontAttributes="Bold" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding ScannedPlayer.Position}" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Dorsal:" FontAttributes="Bold" />
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding ScannedPlayer.ShirtNumber, StringFormat='#{0}'}" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Documento:" FontAttributes="Bold" />
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding ScannedPlayer.DocumentNumber}" />

                        <Label Grid.Row="4" Grid.Column="0" Text="Nacimiento:" FontAttributes="Bold" />
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding ScannedPlayer.BirthDate, StringFormat='{0:dd/MM/yyyy}'}" />

                        <Label Grid.Row="5" Grid.Column="0" Text="Código QR:" FontAttributes="Bold" />
                        <Label Grid.Row="5" Grid.Column="1" Text="{Binding ScannedPlayer.QRCode}" FontSize="12" />
                    </Grid>
                </Frame>

                <Button Text="Escanear Otro Jugador"
                        Command="{Binding ResetScannerCommand}"
                        BackgroundColor="#FF9800"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="50" />
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               Color="{StaticResource Primary}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
